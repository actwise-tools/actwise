{
  "openapi": "3.1.0",
  "info": {
    "title": "docenter Copilot grounding proxy",
    "description": "Live NICE Actimize documentation search for Copilot Studio grounding (Option D).",
    "version": "0.1.0"
  },
  "paths": {
    "/healthz": {
      "get": {
        "tags": [
          "meta"
        ],
        "summary": "Healthz",
        "description": "Unauthenticated liveness probe (for tunnels / load balancers).",
        "operationId": "healthz_healthz_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Healthz Healthz Get"
                }
              }
            }
          }
        }
      }
    },
    "/search": {
      "get": {
        "tags": [
          "search"
        ],
        "summary": "Search",
        "description": "Search the live portal and return results shaped for Copilot Studio's\n``System.SearchResults`` table (Title / Content / ContentLocation).",
        "operationId": "searchDocs",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "The user's search query.",
              "title": "Q"
            },
            "description": "The user's search query."
          },
          {
            "name": "product",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Product key/name, e.g. actone, ifm, sam.",
              "title": "Product"
            },
            "description": "Product key/name, e.g. actone, ifm, sam."
          },
          {
            "name": "doc_version",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Doc version, e.g. 10.1, 11.2.",
              "title": "Doc Version"
            },
            "description": "Doc version, e.g. 10.1, 11.2."
          },
          {
            "name": "guide",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Guide type, e.g. implementer, reference.",
              "title": "Guide"
            },
            "description": "Guide type, e.g. implementer, reference."
          },
          {
            "name": "max",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 20,
              "minimum": 1,
              "description": "Max results (Copilot token budget).",
              "default": 5,
              "title": "Max"
            },
            "description": "Max results (Copilot token budget)."
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "description": "Result page.",
              "default": 1,
              "title": "Page"
            },
            "description": "Result page."
          },
          {
            "name": "retry",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "description": "Auto-retry the portal's spelling/synonym suggestion when empty.",
              "default": true,
              "title": "Retry"
            },
            "description": "Auto-retry the portal's spelling/synonym suggestion when empty."
          },
          {
            "name": "X-API-Key",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Api-Key"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "SearchResponse": {
        "properties": {
          "value": {
            "items": {
              "$ref": "#/components/schemas/SearchResultItem"
            },
            "type": "array",
            "title": "Value",
            "description": "Search results."
          },
          "originalQuery": {
            "type": "string",
            "title": "Originalquery",
            "description": "The query as received."
          },
          "correctedQuery": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Correctedquery",
            "description": "Spelling/synonym correction the portal applied, if any."
          },
          "suggestions": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Suggestions",
            "description": "Alternative query suggestions when results are sparse."
          }
        },
        "type": "object",
        "required": [
          "originalQuery"
        ],
        "title": "SearchResponse",
        "description": "Envelope returned to the Copilot custom connector."
      },
      "SearchResultItem": {
        "properties": {
          "Title": {
            "type": "string",
            "title": "Title",
            "description": "Result title (becomes the citation title)."
          },
          "ContentLocation": {
            "type": "string",
            "title": "Contentlocation",
            "description": "Canonical portal URL — the citation Copilot surfaces."
          },
          "Content": {
            "type": "string",
            "title": "Content",
            "description": "Snippet/body the model reads to ground its answer."
          }
        },
        "type": "object",
        "required": [
          "Title",
          "ContentLocation",
          "Content"
        ],
        "title": "SearchResultItem",
        "description": "One result, shaped for Copilot Studio's ``System.SearchResults`` table.\n\nThe property names match the Copilot schema exactly so the custom connector\ncan auto-map them in ``OnKnowledgeRequested``."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}